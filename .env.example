# RenalCare OS - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# AI API Keys
# ============================================================
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_API_KEY=your-google-gemini-key-here

# ============================================================
# Database Configuration (Optional - uses in-memory if not set)
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/renalcare_db

# ============================================================
# Application Settings
# ============================================================
APP_ENV=development
APP_SECRET_KEY=your-secret-key-here
DEBUG=true

# ============================================================
# Backend API
# ============================================================
BACKEND_URL=http://localhost:8000

# ============================================================
# Feature Flags
# ============================================================
ENABLE_FOOD_VISION=false
ENABLE_EHR_INTEGRATION=false
